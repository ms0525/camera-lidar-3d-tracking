# Public deployment metadata
# Set this to the public repository containing the exact source used by the app.
DASHBOARD_SOURCE_URL=https://github.com/YOUR_USERNAME/YOUR_REPOSITORY

# Public hosts should leave both live-mode guards disabled.
DASHBOARD_ENABLE_LIVE=0
DASHBOARD_TRUSTED_LOCAL=0

# Optional localhost-only live configuration. These paths stay on your machine.
DASHBOARD_DATASET_ROOT=C:\path\to\KITTI\tracking
DASHBOARD_SEQUENCE=0000
DASHBOARD_YOLO11_MODEL=C:\path\to\yolo11s.pt
DASHBOARD_YOLO26_MODEL=C:\path\to\yolo26s.pt
DASHBOARD_DEVICE=0
DASHBOARD_EMBEDDER_GPU=0
